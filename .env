# Docker Compose 环境配置
# 用于生产环境部署

# 环境标识
ENV=prod
DEBUG=false

# Worker 数量
WORKERS=1

# JWT 密钥（随机生成）
JWT_SECRET_KEY=5fNcWyX7IUSW_xSVhBTOCkJ2cZRT-7Hb8zYTFNambjg

# 数据库配置（使用现有外部服务）
DB_HOST=192.168.0.100
DB_PORT=5432
DB_USER=superset
DB_PASSWORD=superset
DB_NAME=fastapi_db

# Redis 配置（使用现有外部服务）
REDIS_HOST=192.168.0.100
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Redis 无密码时保持注释

# Namespace 配置（JSON 格式）
NAMESPACE_CONFIG={"meeting_gamma":"集成验证","meeting_app":"APP","meeting_av":"音视频","meeting_public":"公共设备","meeting_perf":"性能设备"}

# 执行机申请权限配置（JSON格式）
ENV_APPLY_AUTH={"dev_key":["meeting_gamma","meeting_app","meeting_perf"]}

# 测试报告 HTML 存储路径（Docker 内部路径）
TEST_REPORT_HTML_PATH=/data/test_reports

# 测试报告外部访问地址（根据实际部署地址修改）
TEST_REPORT_EXTERNAL_BASE_URL=http://localhost:8000

# 执行主机IP（可选）
HOST_IP=