# 数据库配置
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=zq_platform

# Redis配置
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT密钥（生产环境必须修改为随机字符串）
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production

# 测试报告外部访问地址
TEST_REPORT_EXTERNAL_BASE_URL=http://your-domain:8000

# 执行主机IP（用于定时任务IP匹配）
HOST_IP=