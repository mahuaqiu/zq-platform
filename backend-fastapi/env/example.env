# 环境配置示例文件
# 复制此文件为对应环境的配置文件并修改

# 环境标识: dev, uat, prod
ENV=dev
DEBUG=true

# 应用配置
APP_NAME=Meeting Test
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置
DB_HOST=192.168.0.102
DB_PORT=5432
DB_USER=superset
DB_PASSWORD=superset
DB_NAME=fastapi_db

# 数据库连接URL（由上面的变量自动拼接，无需手动配置）
# 如果需要使用SQLite: DATABASE_URL=sqlite+aiosqlite:///./app.db
# 如果需要使用MySQL: DATABASE_URL=mysql+aiomysql://user:password@host:port/dbname

# Redis配置
REDIS_HOST=192.168.0.102
REDIS_PORT=6379
# REDIS_PASSWORD=superset  # Redis无密码时注释掉
REDIS_DB=0
# Redis连接URL（由上面的变量自动拼接，无需手动配置）
# REDIS_URL=redis://:password@host:port/db

# 缓存配置
CACHE_DEFAULT_EXPIRE=300
CACHE_PREFIX=fastapi:

# 执行主机IP配置（可选，用于定时任务IP匹配）
HOST_IP=

# 测试报告 HTML 存储路径（Windows 环境使用本地路径）
TEST_REPORT_HTML_PATH=D:/test_reports
