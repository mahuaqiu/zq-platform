# 环境配置示例文件
# 复制此文件为对应环境的配置文件并修改（如 dev.env、uat.env、prod.env）

# ==================== 环境标识 ====================
ENV=dev
DEBUG=true

# ==================== 应用配置 ====================
APP_NAME=zq-platform
APP_HOST=0.0.0.0
APP_PORT=8000

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=fastapi_db

# 数据库连接URL（由上面的变量自动拼接，无需手动配置）
# 如果需要使用SQLite: DATABASE_URL=sqlite+aiosqlite:///./app.db
# 如果需要使用MySQL: DATABASE_URL=mysql+aiomysql://user:password@host:port/dbname

# ==================== 分页配置 ====================
PAGE_SIZE=20
PAGE_MAX_SIZE=100

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_password  # Redis无密码时注释掉
REDIS_DB=0
# Redis连接URL（由上面的变量自动拼接，无需手动配置）

# ==================== 缓存配置 ====================
CACHE_DEFAULT_EXPIRE=300
CACHE_PREFIX=fastapi:

# ==================== JWT配置 ====================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== 测试报告配置 ====================
# 超时自动分析时间（分钟）
ANALYZE_TIMEOUT_MINUTES=30
# 本地AI服务地址（可选）
# AI_ANALYSIS_SERVICE_URL=http://localhost:5000
# 上报API专用Token（可选）
# TEST_REPORT_API_TOKEN=your-api-token
# 测试报告外部访问地址
TEST_REPORT_EXTERNAL_BASE_URL=http://localhost:8000
# 任务聚合配置（JSON格式，可选）
# TASK_AGGREGATION_CONFIG={"group1": ["task1", "task2"]}

# ==================== 执行主机配置 ====================
# 执行主机IP（用于定时任务IP匹配，可选）
HOST_IP=

# ==================== 测试报告存储配置 ====================
# HTML文件存储路径（Windows环境使用本地路径）
TEST_REPORT_HTML_PATH=/data/test_reports
# HTML文件保留天数
TEST_REPORT_HTML_CLEANUP_DAYS=15
# 明细记录保留天数
TEST_REPORT_DETAIL_CLEANUP_DAYS=30

# ==================== NanoClaw AI助手配置 ====================
NANOCLAW_API_URL=http://localhost:8080
NANOCLAW_API_TOKEN=your-nanoclaw-token
# 回调接收地址（NanoClaw处理完成后主动推送回复）
NANOCLAW_CALLBACK_URL=http://localhost:8000/api/public/callback/message

# ==================== AI上下文管理配置 ====================
# 时间窗口（分钟），超过此时间创建新会话
CONTEXT_TIME_WINDOW=120
# 消息数量上限，达到上限清除上下文
CONTEXT_MESSAGE_LIMIT=50
# 清除后保留消息数（用于恢复上下文）
CONTEXT_RECOVERY_COUNT=10

# ==================== 文件存储配置 ====================
# 存储类型: local/oss/minio/azure
FILE_STORAGE_TYPE=minio
# 本地存储路径（FILE_STORAGE_TYPE=local时使用）
# FILE_STORAGE_LOCAL_PATH=/data/files

# OSS配置（阿里云OSS）
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET_NAME=your-bucket-name

# Minio配置
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET_NAME=zq-platform
# MINIO_SECURE=false

# Azure配置
# AZURE_ACCOUNT_NAME=your-account-name
# AZURE_ACCOUNT_KEY=your-account-key
# AZURE_CONTAINER_NAME=your-container-name

# ==================== OAuth配置 ====================
# 是否给OAuth用户授予管理员权限
GRANT_ADMIN_TO_OAUTH_USER=false

# Gitee OAuth
# GITEE_CLIENT_ID=your-client-id
# GITEE_CLIENT_SECRET=your-client-secret
# GITEE_REDIRECT_URI=https://your-domain/oauth/gitee/callback

# GitHub OAuth
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret
# GITHUB_REDIRECT_URI=https://your-domain/oauth/github/callback

# QQ OAuth
# QQ_APP_ID=your-app-id
# QQ_APP_KEY=your-app-key
# QQ_REDIRECT_URI=https://your-domain/oauth/qq/callback

# Google OAuth
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain/oauth/google/callback

# 微信 OAuth
# WECHAT_APP_ID=your-app-id
# WECHAT_APP_SECRET=your-app-secret
# WECHAT_REDIRECT_URI=https://your-domain/oauth/wechat/callback

# Microsoft OAuth
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_REDIRECT_URI=https://your-domain/oauth/microsoft/callback

# 钉钉 OAuth
# DINGTALK_APP_ID=your-app-id
# DINGTALK_APP_SECRET=your-app-secret
# DINGTALK_REDIRECT_URI=https://your-domain/oauth/dingtalk/callback

# 飞书 OAuth
# FEISHU_APP_ID=your-app-id
# FEISHU_APP_SECRET=your-app-secret
# FEISHU_REDIRECT_URI=https://your-domain/oauth/feishu/callback

# ==================== Namespace配置 ====================
# Namespace 配置（JSON 格式）
# 键为 namespace value，值为显示标签
# 示例：NAMESPACE_CONFIG={"meeting_gamma":"集成验证","meeting_app":"APP","meeting_av":"音视频","meeting_public":"公共设备"}
NAMESPACE_CONFIG=